# ─────────────────────────────────────────────────────────────────────────────
# RJL — Respaldo Jurídico Laboral · Variables de Entorno
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA subas .env.local a git (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000        # En prod: https://tu-dominio.com
NEXT_PUBLIC_APP_NAME=RJL Respaldo Jurídico Laboral

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # NUNCA exponer al cliente

# Anthropic Claude (NUNCA exponer al cliente — server-side only)
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key

# Stripe (stripe.com/dashboard)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret    # En prod: sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret  # whsec del endpoint registrado
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_PRICE_ID_MONTHLY=price_your-monthly-price-id  # $200 MXN/month

# Upstash Redis (upstash.com — rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Negocio / Legal
# Salario mínimo general vigente en MXN/día. Actualizar cada enero (DOF).
# 2024: 248.93 | 2025: 278.80 | ZFN 2025: 419.88
SALARIO_MINIMO_DIA=278.80

# Feature flags
NEXT_PUBLIC_FREE_CHAT_LIMIT=3                    # Preguntas gratuitas/IP/día
